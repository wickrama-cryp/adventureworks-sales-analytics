      <aliases enabled='yes' />
      <column caption='Line Revenue' datatype='real' name='[Calculation_0536306892001285]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[unitprice] * (1 - [unitpricediscount]) * [orderqty]' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_0536306910019590]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([totaldue]) / COUNTD([salesorderid])' />
      </column>
      <column caption='Customer Segment' datatype='string' name='[Calculation_0536307073466375]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([totaldue]) &gt;= 800000 THEN &quot;Platinum&quot;&#13;&#10;ELSEIF SUM([totaldue]) &gt;= 600000 THEN &quot;Gold&quot;&#13;&#10;ELSEIF SUM([totaldue]) &gt;= 400000 THEN &quot;Silver&quot;&#13;&#10;ELSE &quot;Bronze&quot;&#13;&#10;END' />
      </column>
      <column caption='Salesperson Name' datatype='string' name='[Calculation_0536307080634376]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[firstname] + &apos; &apos; + [lastname]' />
      </column>
      <column caption='YoY Growth %' datatype='real' name='[Calculation_0536307086053385]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([totaldue]) - LOOKUP(SUM([totaldue]), -1)) / ABS(LOOKUP(SUM([totaldue]),-1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_0536307240923150]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([salesorderid])' />
      </column>
      <column caption='Customer Revenue LOD' datatype='real' name='[Calculation_0536307253215248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customerid] : SUM([totaldue]) }' />
      </column>
      <column caption='Territory Avg Revenue' datatype='real' name='[Calculation_0536307254255633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [name] : AVG({ FIXED [customerid] : SUM([totaldue]) }) }' />
      </column>
      <column caption='Above Territory Average' datatype='boolean' name='[Calculation_0536307254755346]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0536307253215248] &gt; [Calculation_0536307254255633]' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_0536307654594580]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customerid])' />
      </column>
